PORT=5000
CORS_ORIGINS=http://localhost:3000
# Atlas Cluster0 (SRV); same logical DB name for scraping, clients, machine-valuation, auth, etc.
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0&retryWrites=true&w=majority
MONGO_URL_SCRAPPING=
MONGO_DBNAME_SCRAPPING=ElectronDB
# Optional: if mongodb+srv fails with querySrv ECONNREFUSED, use public DNS + prefer IPv4
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# MONGO_IPV4_FIRST=1
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_CACHE=false
AUTH_SECRET=change-me
SUPER_ADMIN_USERNAME=admin000
SUPER_ADMIN_PASSWORD=admin000
