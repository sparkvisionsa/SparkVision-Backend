PORT=5000
CORS_ORIGINS=http://localhost:3000
# Atlas Cluster0 (SRV); same logical DB name for scraping, clients, machine-valuation, auth, etc.
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0&retryWrites=true&w=majority
MONGO_URL_SCRAPPING=
MONGO_DBNAME_SCRAPPING=ElectronDB
# Optional: if mongodb+srv fails with querySrv ECONNREFUSED, use public DNS + prefer IPv4
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# MONGO_IPV4_FIRST=1
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_CACHE=false
SESSION_TIMEOUT_MINUTES=1440
AUTH_SECRET=change-me
SUPER_ADMIN_USERNAME=admin000
SUPER_ADMIN_PASSWORD=admin000
# DigitalOcean Spaces — رفع ملفات المعاين في تقييم الآلات (mv_projects.inspectorFiles)
DO_SPACES_ACCESS_KEY_NAME=
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=inspector-files
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_ORIGIN_ENDPOINT=https://inspector-files.sfo3.digitaloceanspaces.com
DO_SPACES_INSPECTOR_PREFIX=mv-inspector
